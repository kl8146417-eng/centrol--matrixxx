# Copy to .env.local and fill in. Never commit real values.

# --- Database (blog storage) ---
# Production: Netlify DB (powered by Neon) auto-injects NETLIFY_DATABASE_URL on Netlify
# after you run `netlify db init`. You do NOT set it by hand there.
# Local dev: set DATABASE_URL to any Postgres/Neon connection string (or paste the
# value of NETLIFY_DATABASE_URL here). The app reads NETLIFY_DATABASE_URL first, then DATABASE_URL.
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# --- Blog API token hashing ---
# Random long secret mixed into the SHA-256 token hash. Generate once, keep stable.
CM_TOKEN_PEPPER=change-me-to-a-long-random-string

# --- Contact form email (optional until contact is wired) ---
RESEND_API_KEY=
CONTACT_TO_EMAIL=contact@centrolmatrix.com

# --- Public site config ---
NEXT_PUBLIC_SITE_URL=https://centrolmatrix.com

# --- Analytics / SEO (client provides; features stay off until set) ---
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_SEARCH_CONSOLE_VERIFICATION=
