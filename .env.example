# Copy to .env.local and fill in. Never commit real values.

# --- Supabase Postgres (blog storage) ---
# Use the POOLED connection string (Supabase: Project Settings -> Database -> Connection pooling).
DATABASE_URL=postgres://postgres.<project>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# --- Blog API token hashing ---
# Random long secret mixed into the SHA-256 token hash. Generate once, keep stable.
CM_TOKEN_PEPPER=change-me-to-a-long-random-string

# --- Contact form email (optional until contact is wired) ---
RESEND_API_KEY=
CONTACT_TO_EMAIL=contact@centrolmatrix.com

# --- Public site config ---
NEXT_PUBLIC_SITE_URL=https://centrolmatrix.com

# --- Analytics / SEO (client provides; features stay off until set) ---
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_SEARCH_CONSOLE_VERIFICATION=
